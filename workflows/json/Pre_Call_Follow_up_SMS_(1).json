    {
      "parameters": {
        "jsCode": "// Get the booking data from the input\nconst data = $input.first().json;\n\n// Get the appointment start time\nconst startTime = new Date(data.startTime);\nconst currentTime = new Date();\n\n// Calculate the difference in milliseconds\nconst timeDifference = startTime.getTime() - currentTime.getTime();\n\n// Convert to days (rounded down to get exact days)\nconst daysUntilAppointment = Math.floor(timeDifference / (1000 * 60 * 60 * 24));\n\n// Calculate hours for more precise checking\nconst hoursUntilAppointment = Math.floor(timeDifference / (1000 * 60 * 60));\n\nconsole.log(`Current check: ${daysUntilAppointment} days, ${hoursUntilAppointment} hours until appointment`);\n\n// Check if it's time to send the 24-hour (1 day before) reminder\n// We'll trigger when it's between 20-28 hours before (to account for timing variations)\nconst shouldSendReminder = hoursUntilAppointment <= 28 && hoursUntilAppointment >= 20;\n\n// Return the data with routing information\nreturn [{\n  json: {\n    ...data,\n    currentDaysUntil: daysUntilAppointment,\n    currentHoursUntil: hoursUntilAppointment,\n    shouldSendReminder: shouldSendReminder,\n    shouldLoop: !shouldSendReminder,\n    checkTime: currentTime.toISOString(),\n    nextAction: shouldSendReminder ? \"send_24h_reminder\" : \"wait_and_loop\"\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
