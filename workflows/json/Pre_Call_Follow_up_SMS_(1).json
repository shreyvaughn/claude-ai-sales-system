    },
    {
      "parameters": {
        "jsCode": "// Get the booking data from the previous node\nconst bookingData = $input.first().json.bookingData;\n\n// Extract start time and attendee timezone\nconst startTime = new Date(bookingData.startTime);\nconst attendeeTimeZone = bookingData.attendeeTimeZone;\nconst currentTime = new Date();\n\n// Calculate the difference in milliseconds\nconst timeDifference = startTime.getTime() - currentTime.getTime();\nconst daysUntilAppointment = Math.ceil(timeDifference / (1000 * 60 * 60 * 24));\nconst hoursUntilAppointment = Math.ceil(timeDifference / (1000 * 60 * 60));\n\n// Format date and time in attendee's timezone\nconst appointmentDate = startTime.toLocaleDateString('en-US', {\n  weekday: 'long',\n  year: 'numeric',\n  month: 'long',\n  day: 'numeric',\n  timeZone: attendeeTimeZone\n});\n\nconst appointmentTime = startTime.toLocaleTimeString('en-US', {\n  hour: 'numeric',\n  minute: '2-digit',\n  hour12: true,\n  timeZone: attendeeTimeZone\n});\n\n// Get timezone abbreviation for display\nconst timeZoneAbbr = startTime.toLocaleTimeString('en-US', {\n  timeZoneName: 'short',\n  timeZone: attendeeTimeZone\n}).split(' ').slice(-1)[0];\n\n// Determine reminder path\nlet reminderPath;\nif (daysUntilAppointment >= 7) {\n  reminderPath = \"7_plus_days\";\n} else if (daysUntilAppointment >= 4 && daysUntilAppointment < 7) {\n  reminderPath = \"4_to_6_days\";\n} else if (daysUntilAppointment >= 2 && daysUntilAppointment < 4) {\n  reminderPath = \"2_to_3_days\";\n} else {\n  reminderPath = \"same_day_24h\";\n}\n\n// Return enhanced data\nreturn [{\n  json: {\n    bookingData: bookingData,\n    daysUntilAppointment: daysUntilAppointment,\n    hoursUntilAppointment: hoursUntilAppointment,\n    reminderPath: reminderPath,\n    formattedDate: appointmentDate,\n    formattedTime: appointmentTime,\n    timeZoneAbbr: timeZoneAbbr,\n    formattedDateTime: `${appointmentDate} at ${appointmentTime} ${timeZoneAbbr}`\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -3620,
        340
      ],
