    {
      "parameters": {
        "jsCode": "// Get the booking data from the input\nconst data = $input.first().json;\n\n// Get the appointment start time\nconst startTime = new Date(data.startTime);\nconst currentTime = new Date();\n\n// Calculate the difference in milliseconds\nconst timeDifference = startTime.getTime() - currentTime.getTime();\n\n// Convert to days (exact float) and rounded down\nconst daysUntilAppointment = Math.floor(timeDifference / (1000 * 60 * 60 * 24));\nconst exactDays = timeDifference / (1000 * 60 * 60 * 24);\n\n// Check if it's time to send the 4-day reminder\n// Optional buffer: between 3.6 and 4.4 days (to account for timing drifts)\nconst shouldSendReminder = exactDays >= 3.6 && exactDays <= 4.4;\n\n// Return the data with routing information\nreturn [{\n  json: {\n    ...data,\n    currentDaysUntil: daysUntilAppointment,\n    exactDaysUntil: exactDays.toFixed(2),\n    shouldSendReminder: shouldSendReminder,\n    shouldLoop: !shouldSendReminder,\n    checkTime: currentTime.toISOString(),\n    nextAction: shouldSendReminder ? \"send_4d_reminder\" : \"wait_and_loop\"\n  }\n}];\n"
      },
